# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Force LF for these
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.py text eol=lf
*.sh text eol=lf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary

# Linguist hints — exclude generated / fixture noise from language stats
packages/*/dist/** linguist-generated=true
**/*.snap linguist-generated=true
docs/** linguist-documentation=true
examples/** linguist-documentation=true
