{
  "name": "docpilot",
  "private": true,
  "version": "0.0.0",
  "description": "Local-first MCP server that turns any public GitHub, GitLab, or Bitbucket repo into fresh, version-pinned documentation for AI coding assistants.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/tamimbinhakim/docpilot#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/docpilot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/docpilot.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "dev": "pnpm --filter docpilot run dev",
    "test": "pnpm -r --filter './packages/*' run test",
    "test:ci": "pnpm -r --filter './packages/*' run test:ci",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck",
    "lint": "pnpm run lint:js && pnpm run lint:py && pnpm run lint:md",
    "lint:js": "biome lint .",
    "lint:py": "ruff check .",
    "lint:md": "prettier --check \"**/*.md\"",
    "format": "pnpm run format:js && pnpm run format:py && pnpm run format:md",
    "format:js": "biome format --write .",
    "format:py": "ruff format .",
    "format:md": "prettier --write \"**/*.md\"",
    "format:check": "pnpm run format:check:js && pnpm run format:check:py && pnpm run format:check:md",
    "format:check:js": "biome format .",
    "format:check:py": "ruff format --check .",
    "format:check:md": "prettier --check \"**/*.md\"",
    "check": "biome check --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^20.16.10",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
