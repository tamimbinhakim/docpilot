{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "lineWidth": 100,
  "indentWidth": 2,
  "indentStyle": "space",
  "quoteStyle": "double",
  "jsxQuoteStyle": "double",
  "trailingCommas": "all",
  "semicolons": "always",
  "arrowParentheses": "always",
  "bracketSpacing": true,
  "endOfLine": "lf"
}
