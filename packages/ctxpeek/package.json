{
  "name": "ctxpeek",
  "version": "0.1.2",
  "description": "ctxpeek (pronounced Context Peek) is a local-first MCP server for fresh, version-pinned repo docs.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/tamimbinhakim/ctxpeek#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/ctxpeek/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/ctxpeek.git",
    "directory": "packages/ctxpeek"
  },
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "windsurf",
    "documentation",
    "github",
    "context7-alternative",
    "ai",
    "llm",
    "stdio"
  ],
  "bin": {
    "ctxpeek": "dist/server.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepack": "pnpm run clean && pnpm run build",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=default --coverage",
    "test:integration": "tsc -b && vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "doctor": "node dist/server.js doctor"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "env-paths": "^3.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "proper-lockfile": "^4.1.2",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "smol-toml": "^1.3.1",
    "undici": "^6.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.16.10",
    "@types/proper-lockfile": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.6",
    "msw": "^2.4.9",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
